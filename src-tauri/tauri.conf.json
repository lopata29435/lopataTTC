{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lopata",
  "identifier": "org.trusttunnel.gui",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lopata",
        "width": 920,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "longDescription": "Lopata — десктопный клиент протокола TrustTunnel с системным треем, автообновлениями и поддержкой tt://-ссылок.",
    "shortDescription": "Lopata — TrustTunnel VPN client",
    "category": "Utility"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["tt"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/lopata29435/lopataTTC/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0MEFFRThFNTZCMTIxRUIKUldUckliRldqdTRLVlB2VzFVVGlYUmR2cVBiekJJQmNGK0FDeXQ0UzhjZXg0Zkh1YVpaVUZTYU8K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
